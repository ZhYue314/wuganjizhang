<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.Wuganjizhang" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_light</item>
        <item name="colorOnPrimary">@android:color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@android:color/black</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor" tools:targetApi="l">?attr/colorPrimaryVariant</item>
        <!-- Customize your theme here. -->
        <item name="colorBackground">@color/bg</item>
        <item name="colorCard">@color/card</item>
        <item name="colorText">@color/text</item>
        <item name="colorText2">@color/text2</item>
        <item name="colorText3">@color/text3</item>
        <item name="colorBorder">@color/border</item>
        <item name="colorSuccess">@color/success</item>
        <item name="colorDanger">@color/danger</item>
        <item name="colorWarning">@color/warning</item>
        <item name="colorPrimaryBg">@color/primary_bg</item>
        <item name="colorIconBackground">@color/icon_background</item>
        <item name="colorExpense">@color/expense</item>
    </style>
    
    <!-- AppBar overlay theme -->
    <style name="AppTheme.AppBarOverlay" parent="ThemeOverlay.AppCompat.Dark.ActionBar" />
    
    <!-- Popup overlay theme -->
    <style name="AppTheme.PopupOverlay" parent="ThemeOverlay.AppCompat.Light" />
</resources>
